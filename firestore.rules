rules_version = '2';

/**
 * TAILOR TRAVELS - FIRESTORE SECURITY RULES
 * Updated to ensure public listing of CMS-driven navigation and content is permitted.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- COLLECTION RULES ---

    // Publicly readable collections (CMS Content)
    // These allow users to browse holidays, destinations, and see menu items.
    match /holidays/{holidayId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /destinations/{destinationId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /trustBadges/{trustBadgeId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /whyBookFeatures/{whyBookFeatureId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /companyStatistics/{companyStatisticId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /navigationItems/{navItemId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /branches/{branchId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    // Special case: Company Info is a singleton document
    match /companyInfo/{documentId} {
      allow get: if true;
      allow list: if true; // Changed to true to support listing if needed by CMS
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    // Private collection: Newsletter Subscribers
    match /newsletterSubscribers/{subscriberId} {
      allow create: if true; // Anyone can sign up
      allow get, list: if isAdmin(); // Only admins can see the list
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Administrative Role management.
     */
    match /roles_admin/{userId} {
      // Allow user to read their own admin document to verify role
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Allow initial setup creation if the user is setting up their own admin account
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Other admin management requires existing admin role
      allow list, update, delete: if isAdmin();
    }
  }
}
