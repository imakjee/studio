rules_version = '2';

/**
 * ELITE ESCAPES - FIRESTORE SECURITY RULES
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- COLLECTION RULES ---

    match /holidays/{holidayId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /destinations/{destinationId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /trustBadges/{trustBadgeId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /whyBookFeatures/{whyBookFeatureId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /companyStatistics/{companyStatisticId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /newsletterSubscribers/{subscriberId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /branches/{branchId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /navigationItems/{navItemId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /companyInfo/{documentId} {
      allow get: if true;
      allow list: if false; 
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Administrative Role management.
     * Modified to allow users to read their own role and allow initial setup.
     */
    match /roles_admin/{userId} {
      // Allow user to read their own admin document to verify role
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Allow initial setup creation (in production this would be more restricted)
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Other admin management requires existing admin role
      allow list, update, delete: if isAdmin();
    }
  }
}