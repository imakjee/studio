rules_version = '2';

/**
 * FIREBASE SECURITY RULES DOCUMENTATION
 * 
 * Core Philosophy:
 * This ruleset implements a "Public Catalog, Private Subscriptions" model for Elite Escapes. 
 * Marketing content (Destinations and Holidays) is globally readable to facilitate 
 * browsing without authentication. User-generated data (Newsletter Subscriptions) 
 * follows a "write-only" pattern for end-users to protect privacy.
 * 
 * Data Structure:
 * - /destinations/{destinationId}: Top-level public collection for travel locations.
 * - /holidays/{holidayId}: Top-level public collection for travel packages.
 * - /newsletterSubscribers/{subscriberId}: Collection for email leads.
 * 
 * Key Security Decisions:
 * - Public Content: Read access is open to all for Destinations and Holidays.
 * - Restricted Writes: Writes to the catalog are blocked as the current schema 
 *   lacks ownership fields (e.g., adminId). This prevents unauthorized content modification.
 * - Subscriber Privacy: Any authenticated user (including anonymous) can subscribe, 
 *   but they cannot read back, update, or delete any subscription data.
 * - Admin Role: Read/Update/Delete access for subscribers is reserved for a future 
 *   administrative role.
 * 
 * Denormalization for Authorization:
 * - The NewsletterSubscriber entity uses the document ID as a relational link to 
 *   the internal 'id' field to ensure path-to-data consistency.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * @description Checks if the request is from an authenticated user (including anonymous).
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Placeholder for administrative access logic. 
     * Defaults to false until a specific admin role or custom claim is implemented.
     */
    function isAdmin() {
      return false; 
    }

    // --- COLLECTION RULES ---

    /**
     * @description Publicly accessible collection of travel destinations.
     * @path /destinations/{destinationId}
     * @allow get (all), list (all)
     * @deny create, update, delete (all - missing ownership context)
     * @principle Public Read with Owner-Only Writes (Writes currently disabled for safety).
     */
    match /destinations/{destinationId} {
      allow get, list: if true;
      // CRITICAL: Cannot implement owner-only writes. The 'Destination' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if false; // TODO: Add admin/owner validation once the schema is updated.
    }

    /**
     * @description Publicly accessible collection of holiday packages.
     * @path /holidays/{holidayId}
     * @allow get (all), list (all)
     * @deny create, update, delete (all - missing ownership context)
     * @principle Public Read with Owner-Only Writes (Writes currently disabled for safety).
     */
    match /holidays/{holidayId} {
      allow get, list: if true;
      // CRITICAL: Cannot implement owner-only writes. The 'Holiday' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if false; // TODO: Add admin/owner validation once the schema is updated.
    }

    /**
     * @description Collection for newsletter subscriptions. Allows creation by any user but restricts reading to admins.
     * @path /newsletterSubscribers/{subscriberId}
     * @allow create (any signed-in/anon user), get/list/update/delete (admin only)
     * @deny get/list/update/delete (standard users)
     * @principle Restricted shared access with relational integrity validation.
     */
    match /newsletterSubscribers/{subscriberId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.id == subscriberId;
      allow update: if resource != null && isAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if resource != null && isAdmin();
    }
  }
}