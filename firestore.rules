rules_version = '2';

/**
 * ELITE ESCAPES - FIRESTORE SECURITY RULES
 * 
 * Core Philosophy:
 * This ruleset implements a centralized administrative control model. Most content 
 * (holidays, destinations, company info) is publicly readable to support an 
 * anonymous browsing experience, while all modification operations are strictly 
 * restricted to users identified as administrators.
 * 
 * Data Structure:
 * The database is organized into flat, top-level collections for primary entities 
 * like /holidays, /destinations, and /branches. A singleton document at 
 * /companyInfo/globalSettings handles site-wide configuration. Administrative 
 * roles are managed via a dedicated /roles_admin collection.
 * 
 * Key Security Decisions:
 * 1. Role-Based Access Control (RBAC): Admin privileges are determined by the 
 *    existence of a document in the /roles_admin collection matching the user's UID.
 * 2. Public Read Access: To optimize for SEO and user experience, holiday 
 *    catalogs and company details are open for 'get' and 'list' operations.
 * 3. Newsletter Privacy: Anyone can subscribe (create), but only administrators 
 *    can view or manage the subscriber list.
 * 4. Structural Segregation: The use of boolean flags (e.g., isFeatured, isPopular) 
 *    within public collections allows for secure, performant querying without 
 *    complex filtering rules.
 * 
 * Denormalization for Authorization:
 * This ruleset utilizes a dedicated /roles_admin collection for Database-Backed 
 * Access Control (DBAC). By checking for the existence of an admin record, 
 * we ensure administrative logic is decoupled from individual content schemas.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * @description Checks if the user is authenticated with any provider.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Determines if the authenticated user has administrative privileges.
     * Checks for the existence of a document in the 'roles_admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Validates that a document exists and the user is an admin.
     * Used for update and delete operations.
     */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the Holiday catalog. Publicly readable, admin writable.
     * @path /holidays/{holidayId}
     * @allow get, list: if true; (Public Access)
     * @deny create: if !isAdmin(); (Non-admins cannot create packages)
     * @principle Public consumption with administrative content management.
     */
    match /holidays/{holidayId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Destination information. Publicly readable, admin writable.
     * @path /destinations/{destinationId}
     * @allow get, list: if true; (Public Access)
     * @deny update: if !isAdmin(); (Mismatched credentials)
     * @principle Centralized control for geographical metadata.
     */
    match /destinations/{destinationId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for static Trust Badges (e.g., ATOL). Publicly readable.
     * @path /trustBadges/{trustBadgeId}
     * @allow get, list: if true;
     * @deny write: if !isAdmin();
     * @principle Protects brand integrity and accreditation markers.
     */
    match /trustBadges/{trustBadgeId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for 'Why Book With Us' features. Publicly readable.
     * @path /whyBookFeatures/{whyBookFeatureId}
     * @allow get, list: if true;
     * @deny write: if !isAdmin();
     * @principle Manages value proposition content.
     */
    match /whyBookFeatures/{whyBookFeatureId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Company Statistics. Publicly readable.
     * @path /companyStatistics/{companyStatisticId}
     * @allow get, list: if true;
     * @deny write: if !isAdmin();
     * @principle Ensures accurate reporting of company scale.
     */
    match /companyStatistics/{companyStatisticId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Newsletter Subscribers. Public creation, Admin management.
     * @path /newsletterSubscribers/{subscriberId}
     * @allow create: if true; (Anonymous subscription permitted)
     * @deny list: if !isAdmin(); (Prevents unauthorized access to PII email list)
     * @principle Open intake with strictly controlled read access for privacy.
     */
    match /newsletterSubscribers/{subscriberId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for physical Branch locations. Publicly readable.
     * @path /branches/{branchId}
     * @allow get, list: if true;
     * @deny delete: if !isAdmin();
     * @principle Public access to contact and location data.
     */
    match /branches/{branchId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for site navigation structures. Publicly readable.
     * @path /navigationItems/{navItemId}
     * @allow get, list: if true;
     * @deny update: if !isAdmin();
     * @principle Protects site structure and UX flow.
     */
    match /navigationItems/{navItemId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for global company settings and hero content.
     * @path /companyInfo/globalSettings
     * @allow get: if true; (List denied as it is a singleton)
     * @deny write: if !isAdmin();
     * @principle Protects the singleton configuration document.
     */
    match /companyInfo/{documentId} {
      allow get: if true;
      allow list: if false; 
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Administrative Role management.
     * @path /roles_admin/{userId}
     * @allow get, list: if isAdmin();
     * @deny write: if !isAdmin(); (Prevents self-promotion)
     * @principle Database-Backed Access Control (DBAC) isolation.
     */
    match /roles_admin/{userId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}