rules_version = '2';

/**
 * ELITE ESCAPES - FIRESTORE SECURITY RULES
 * Optimized for dynamic content fetching and administrative control.
 * Trigger Update: February 2026 - Performance Patch
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- COLLECTION RULES ---

    // CMS Content - Publicly readable
    match /holidays/{holidayId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /destinations/{destinationId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /trustBadges/{trustBadgeId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /whyBookFeatures/{whyBookFeatureId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /companyStatistics/{companyStatisticId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /navigationItems/{navItemId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /branches/{branchId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    // Company Info - Singleton
    match /companyInfo/{documentId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    // Newsletter - Public create, Admin read
    match /newsletterSubscribers/{subscriberId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    // Admin Roles (DBAC)
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow list, update, delete: if isAdmin();
    }
  }
}
