rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ELITE ESCAPES SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset implements a Public Content / Private Submission model.
     * Content entities (Packages, Destinations, Branches) are optimized for high-performance
     * public browsing (Query as Permission), while user-submitted data (Newsletter)
     * is protected for privacy.
     *
     * Data Structure:
     * - /holiday_packages: Public travel deals.
     * - /destinations: Public geographical info.
     * - /branch_locations: Public office locations.
     * - /newsletter_subscribers: User-submitted subscriptions (Anonymous Create).
     *
     * Key Security Decisions:
     * - Public Read: Standard for travel marketplaces to ensure SEO and ease of access.
     * - Admin Writes: All content modifications are restricted to administrative
     *   backends (represented here as `if false` until admin roles are defined).
     * - Anonymous Submission: Newsletter sign-ups are allowed for any authenticated
     *   user (including Firebase Anonymous Auth) but cannot be read back by the user.
     *
     * Denormalization for Authorization:
     * - This architecture uses QAP (Query as Permission). Flags like 'isFeatured'
     *   and 'isPopular' are embedded in documents to allow simple listing without
     *   complex join-style security checks.
     */

    /**
     * STEP 1: IR ANALYSIS & SYNTHESIS
     * 1. HolidayPackage: Public Read / Restricted Write.
     *    - No ownership field present. Admin-only writes.
     * 2. Destination: Public Read / Restricted Write.
     *    - No ownership field present. Admin-only writes.
     * 3. BranchLocation: Public Read / Restricted Write.
     *    - No ownership field present. Admin-only writes.
     * 4. NewsletterSubscriber: Self-Creation (Anonymous).
     *    - Restricted Reads/Updates/Deletes to protect subscriber privacy.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    /**
     * @description Publicly accessible holiday packages for browsing and filtering.
     * @path /holiday_packages/{holidayPackageId}
     * @allow (get, list) for any user.
     * @deny (create, update, delete) for any non-admin user.
     * @principle Public read access for marketing content with strictly controlled writes.
     */
    match /holiday_packages/{holidayPackageId} {
      allow get, list: if true;
      // CRITICAL: Cannot implement owner-only writes. The 'HolidayPackage' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if false; // TODO: Add administrative role check once admin schema is defined.
    }

    /**
     * @description Publicly accessible destination information.
     * @path /destinations/{destinationId}
     * @allow (get, list) for any user.
     * @deny (create, update, delete) for any non-admin user.
     * @principle Public read access for marketing content with strictly controlled writes.
     */
    match /destinations/{destinationId} {
      allow get, list: if true;
      // CRITICAL: Cannot implement owner-only writes. The 'Destination' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if false; // TODO: Add administrative role check once admin schema is defined.
    }

    /**
     * @description Publicly accessible physical branch locations.
     * @path /branch_locations/{branchLocationId}
     * @allow (get, list) for any user.
     * @deny (create, update, delete) for any non-admin user.
     * @principle Public read access for support info with strictly controlled writes.
     */
    match /branch_locations/{branchLocationId} {
      allow get, list: if true;
      // CRITICAL: Cannot implement owner-only writes. The 'BranchLocation' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if false; // TODO: Add administrative role check once admin schema is defined.
    }

    /**
     * @description Secure collection for newsletter signups.
     * @path /newsletter_subscribers/{subscriberId}
     * @allow (create) for any signed-in user (including anonymous).
     * @deny (get, list, update, delete) to prevent unauthorized access to the email list.
     * @principle Anonymous write-only pattern to protect user privacy while allowing lead capture.
     */
    match /newsletter_subscribers/{subscriberId} {
      allow get, list: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}